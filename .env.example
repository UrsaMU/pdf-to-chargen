# ─── chargen-extract settings ────────────────────────────────────────────────
#
# Copy this file to .env and fill in the values you need.
# CLI flags always take precedence over values set here.
#
# Provider is auto-detected: if OPENAI_API_KEY or OPENAI_BASE_URL is set,
# the OpenAI-compatible path is used. Otherwise Anthropic is used.
# Override with CHARGEN_PROVIDER if both keys are present.

# ─── Provider ────────────────────────────────────────────────────────────────

# Explicit provider selection (optional — usually auto-detected)
# CHARGEN_PROVIDER=anthropic   # or: openai

# ─── Anthropic ───────────────────────────────────────────────────────────────

# ANTHROPIC_API_KEY=sk-ant-...

# ─── OpenAI-compatible ───────────────────────────────────────────────────────
# Works with: OpenAI, Groq, Together AI, Mistral, Ollama, LM Studio,
#             Fireworks, Perplexity, Anyscale, any OpenAI-spec endpoint.

# OPENAI_API_KEY=sk-...

# Custom base URL — omit for api.openai.com
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_BASE_URL=https://api.together.xyz/v1
# OPENAI_BASE_URL=https://api.mistral.ai/v1
# OPENAI_BASE_URL=http://localhost:11434/v1        # Ollama
# OPENAI_BASE_URL=http://localhost:1234/v1         # LM Studio

# ─── Model ───────────────────────────────────────────────────────────────────
# Default: claude-sonnet-4-6 (Anthropic) or gpt-4o (OpenAI-compatible)

# CHARGEN_MODEL=claude-sonnet-4-6
# CHARGEN_MODEL=gpt-4o
# CHARGEN_MODEL=llama3-70b-8192          # Groq
# CHARGEN_MODEL=mistral-large-latest     # Mistral
# CHARGEN_MODEL=llama3:70b               # Ollama

# ─── Pipeline settings ───────────────────────────────────────────────────────
# These can also be passed as CLI flags (--text, --output, --system, etc.)
# CLI flags take precedence.

# CHARGEN_TEXT_DIR=./books/text
# CHARGEN_OUTPUT_DIR=./ursamu
# CHARGEN_SYSTEM=Shadowrun 5e
# CHARGEN_MAX_CHARS=150000

# Set to true to skip all confirmation checkpoints (CI/headless mode)
# CHARGEN_CI=false
